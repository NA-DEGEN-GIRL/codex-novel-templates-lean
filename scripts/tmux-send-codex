#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  tmux-send-codex SESSION MESSAGE [CONFIRM_SECONDS] [CAPTURE_LINES]

Sends a prompt to a Codex tmux session, waits 3 seconds, presses Enter,
then checks whether `Working` appears within the confirm window.
If not, it sends Enter once more and checks again.
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -lt 2 ]]; then
  usage >&2
  exit 64
fi

SESSION="$1"
MESSAGE="$2"
CONFIRM_SECONDS="${3:-2}"
CAPTURE_LINES="${4:-60}"
SCRIPT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
EVENT_NOVEL_DIR="${NOVEL_EVENT_DIR:-${SCRIPT_ROOT}}"

log_event() {
  python3 "${SCRIPT_ROOT}/scripts/event-log.py" "${EVENT_NOVEL_DIR}" "$@" >/dev/null 2>&1 || true
}

capture_pane() {
  tmux capture-pane -t "${SESSION}" -p -S "-${CAPTURE_LINES}" 2>/dev/null
}

extract_delta() {
  local before="$1"
  local after="$2"
  if [[ "${after}" == "${before}"* ]]; then
    printf '%s' "${after#"${before}"}"
  else
    printf '%s' "${after}"
  fi
}

has_working_marker() {
  local pane="$1"
  grep -Eq '\b(Working|Explored|Edited|Ran|Reading|Searching|Planning|Analyzing|Applying|Patching)\b' <<<"${pane}"
}

has_response_block() {
  local pane="$1"
  grep -Eq '^[[:space:]]*• ' <<<"${pane}"
}

first_message_line() {
  printf '%s\n' "${MESSAGE}" | sed -n '1p'
}

last_prompt_line() {
  local pane="$1"
  awk '
    /^[[:space:]]*(❯|>|›)/ { line = $0 }
    END { if (line != "") print line }
  ' <<<"${pane}"
}

last_nonempty_line() {
  local pane="$1"
  awk '
    NF { line = $0 }
    END { if (line != "") print line }
  ' <<<"${pane}"
}

message_still_waiting() {
  local pane="$1"
  local first_line
  local last_prompt
  local last_nonempty
  first_line="$(first_message_line)"
  [[ -n "${first_line}" ]] || return 1
  last_prompt="$(last_prompt_line "${pane}")"
  [[ -n "${last_prompt}" ]] || return 1
  last_nonempty="$(last_nonempty_line "${pane}")"

  if ! [[ "${last_prompt}" == *"› ${first_line}" ]] && \
     ! [[ "${last_prompt}" == *"❯ ${first_line}" ]] && \
     ! [[ "${last_prompt}" == *"> ${first_line}" ]]; then
    return 1
  fi

  if [[ "${last_nonempty}" == *"Messages to be submitted after next tool call"* ]]; then
    return 0
  fi

  [[ "${last_nonempty}" == "${last_prompt}" ]]
}

if ! capture_pane >/dev/null; then
  log_event tmux_send_codex_result "status=SESSION_MISSING" "session=${SESSION}" "capture_lines=${CAPTURE_LINES}"
  echo "SESSION_MISSING session=${SESSION}"
  exit 3
fi

log_event tmux_send_codex_start \
  "session=${SESSION}" \
  "confirm_seconds=${CONFIRM_SECONDS}" \
  "capture_lines=${CAPTURE_LINES}" \
  "message_bytes=${#MESSAGE}"
before_pane="$(capture_pane)"
tmux send-keys -t "${SESSION}" -l "${MESSAGE}"
sleep 3
tmux send-keys -t "${SESSION}" Enter
sleep "${CONFIRM_SECONDS}"

pane="$(capture_pane)"
delta="$(extract_delta "${before_pane}" "${pane}")"
if has_working_marker "${delta}"; then
  log_event tmux_send_codex_result "status=WORKING_CONFIRMED" "session=${SESSION}"
  echo "WORKING_CONFIRMED session=${SESSION}"
  exit 0
fi
if has_response_block "${delta}"; then
  log_event tmux_send_codex_result "status=RESPONSE_CONFIRMED" "session=${SESSION}"
  echo "RESPONSE_CONFIRMED session=${SESSION}"
  exit 0
fi
if ! message_still_waiting "${pane}"; then
  log_event tmux_send_codex_result "status=PROMPT_DISAPPEARED" "session=${SESSION}"
  echo "PROMPT_DISAPPEARED session=${SESSION}"
  exit 0
fi

tmux send-keys -t "${SESSION}" Enter
sleep "${CONFIRM_SECONDS}"
pane="$(capture_pane)"
delta="$(extract_delta "${before_pane}" "${pane}")"
if has_working_marker "${delta}"; then
  log_event tmux_send_codex_result "status=WORKING_CONFIRMED_AFTER_RETRY" "session=${SESSION}"
  echo "WORKING_CONFIRMED_AFTER_RETRY session=${SESSION}"
  exit 0
fi
if has_response_block "${delta}"; then
  log_event tmux_send_codex_result "status=RESPONSE_CONFIRMED_AFTER_RETRY" "session=${SESSION}"
  echo "RESPONSE_CONFIRMED_AFTER_RETRY session=${SESSION}"
  exit 0
fi
if ! message_still_waiting "${pane}"; then
  log_event tmux_send_codex_result "status=PROMPT_DISAPPEARED_AFTER_RETRY" "session=${SESSION}"
  echo "PROMPT_DISAPPEARED_AFTER_RETRY session=${SESSION}"
  exit 0
fi

log_event tmux_send_codex_result "status=NO_START_SIGNAL" "session=${SESSION}"
echo "NO_START_SIGNAL session=${SESSION}"
exit 1
