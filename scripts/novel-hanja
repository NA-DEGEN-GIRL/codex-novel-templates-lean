#!/usr/bin/env python3
import argparse
import json
import os
import sys


def _load_module():
    server_dir = "/root/novel/mcp-novel-hanja"
    if server_dir not in sys.path:
        sys.path.insert(0, server_dir)
    import hanja_server  # type: ignore

    return hanja_server


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Codex wrapper for mcp-novel-hanja tool functions."
    )
    parser.add_argument("tool", help="Tool name, e.g. hanja_lookup, hanja_search")
    parser.add_argument(
        "params",
        nargs="*",
        help="Parameters as key=value. Example: text='天外歸還'",
    )
    parser.add_argument(
        "--json",
        dest="json_payload",
        help="Parameters as JSON object string.",
    )
    args = parser.parse_args()

    mod = _load_module()
    fn = getattr(mod, args.tool, None)
    if fn is None or not callable(fn):
        print(f"Unknown tool: {args.tool}", file=sys.stderr)
        return 2

    kwargs = {}
    if args.json_payload:
        try:
            kwargs = json.loads(args.json_payload)
        except json.JSONDecodeError as e:
            print(f"Invalid JSON payload: {e}", file=sys.stderr)
            return 2
    else:
        for raw in args.params:
            if "=" not in raw:
                print(f"Invalid param '{raw}'. Use key=value format.", file=sys.stderr)
                return 2
            key, value = raw.split("=", 1)
            try:
                kwargs[key] = json.loads(value)
            except json.JSONDecodeError:
                kwargs[key] = value

    result = fn(**kwargs)
    print(result)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
