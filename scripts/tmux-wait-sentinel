#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  tmux-wait-sentinel SESSION SENTINEL [TIMEOUT_SECONDS] [POLL_SECONDS] [CAPTURE_LINES] [ALLOW_EXISTING] [SENTINEL_FILE]

Waits until a tmux pane emits the given sentinel as a standalone line in new output,
or until timeout.
By default it ignores sentinel text that was already present in the pane at start time.
Outputs a compact status line for supervisor scripts/prompts.
Recommended sentinel form is an exact line with a run nonce, e.g.
`WRITER_DONE chapter-05.md :: run=20260407-ep05-a1c9`.

Examples:
  scripts/tmux-wait-sentinel write-001 "WRITER_DONE chapter-05.md :: run=20260407-ep05-a1c9" 1800 2 200
  scripts/tmux-wait-sentinel write-001 "FIX_DONE chapter-05 :: run=20260407-fix05-b13e" 600 1 120
  scripts/tmux-wait-sentinel write-001 "WRITER_DONE chapter-05.md :: run=20260407-ep05-a1c9" 1800 2 200 0 tmp/sentinels/chapter-05.done
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -lt 2 ]]; then
  usage >&2
  exit 64
fi

SESSION="$1"
SENTINEL="$2"
TIMEOUT="${3:-1800}"
POLL="${4:-2}"
CAPTURE_LINES="${5:-200}"
ALLOW_EXISTING="${6:-0}"
SENTINEL_FILE="${7:-}"
SCRIPT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
EVENT_NOVEL_DIR="${NOVEL_EVENT_DIR:-${SCRIPT_ROOT}}"

log_event() {
  python3 "${SCRIPT_ROOT}/scripts/event-log.py" "${EVENT_NOVEL_DIR}" "$@" >/dev/null 2>&1 || true
}

deadline=$(( $(date +%s) + TIMEOUT ))

capture_pane() {
  tmux capture-pane -t "${SESSION}" -p -S "-${CAPTURE_LINES}" 2>/dev/null
}

tail_window() {
  local text="$1"
  printf '%s\n' "${text}" | tail -n 20
}

extract_delta() {
  local before="$1"
  local after="$2"
  if [[ "${after}" == "${before}"* ]]; then
    printf '%s' "${after#"${before}"}"
  else
    printf '%s' "${after}"
  fi
}

has_exact_sentinel_line() {
  local text="$1"
  local line
  local normalized_line
  local normalized_sentinel
  normalized_sentinel="${SENTINEL%.md}"
  while IFS= read -r line; do
    line="${line%$'\r'}"
    line="$(printf '%s' "${line}" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')"
    while true; do
      case "${line}" in
        "● "*) line="${line#??}" ;;
        "• "*) line="${line#??}" ;;
        "└ "*) line="${line#??}" ;;
        "│ "*) line="${line#??}" ;;
        *) break ;;
      esac
      line="$(printf '%s' "${line}" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')"
    done
    normalized_line="${line%.md}"
    if [[ "${line}" == "${SENTINEL}" || "${normalized_line}" == "${normalized_sentinel}" ]]; then
      return 0
    fi
  done <<< "${text}"
  return 1
}

has_sentinel_file() {
  [[ -n "${SENTINEL_FILE}" ]] || return 1
  [[ -f "${SENTINEL_FILE}" ]] || return 1
  local file_content
  file_content="$(<"${SENTINEL_FILE}")"
  has_exact_sentinel_line "${file_content}"
}

if ! before_pane="$(capture_pane)"; then
  log_event tmux_wait_sentinel_result "status=SESSION_MISSING" "session=${SESSION}" "sentinel=${SENTINEL}"
  echo "SESSION_MISSING session=${SESSION}"
  exit 3
fi

log_event tmux_wait_sentinel_start \
  "session=${SESSION}" \
  "sentinel=${SENTINEL}" \
  "timeout=${TIMEOUT}" \
  "poll=${POLL}" \
  "capture_lines=${CAPTURE_LINES}" \
  "allow_existing=${ALLOW_EXISTING}" \
  "sentinel_file=${SENTINEL_FILE:-none}"
if [[ "${ALLOW_EXISTING}" == "1" ]]; then
  before_tail="$(tail_window "${before_pane}")"
  if has_exact_sentinel_line "${before_tail}"; then
    log_event tmux_wait_sentinel_result "status=SENTINEL_FOUND" "session=${SESSION}" "sentinel=${SENTINEL}" "mode=already_present"
    echo "SENTINEL_FOUND session=${SESSION} sentinel=${SENTINEL} mode=already_present"
    exit 0
  fi
  if has_sentinel_file; then
    log_event tmux_wait_sentinel_result "status=SENTINEL_FOUND" "session=${SESSION}" "sentinel=${SENTINEL}" "mode=file_present"
    echo "SENTINEL_FOUND session=${SESSION} sentinel=${SENTINEL} mode=file_present"
    exit 0
  fi
fi

echo "WAITING session=${SESSION} sentinel=${SENTINEL}"

while true; do
  now=$(date +%s)
  if (( now >= deadline )); then
    log_event tmux_wait_sentinel_result "status=TIMEOUT" "session=${SESSION}" "sentinel=${SENTINEL}"
    echo "TIMEOUT session=${SESSION} sentinel=${SENTINEL}"
    exit 2
  fi

  if ! pane="$(capture_pane)"; then
    log_event tmux_wait_sentinel_result "status=SESSION_MISSING" "session=${SESSION}" "sentinel=${SENTINEL}"
    echo "SESSION_MISSING session=${SESSION}"
    exit 3
  fi

  delta="$(extract_delta "${before_pane}" "${pane}")"
  if has_exact_sentinel_line "${delta}"; then
    log_event tmux_wait_sentinel_result "status=SENTINEL_FOUND" "session=${SESSION}" "sentinel=${SENTINEL}" "mode=delta"
    echo "SENTINEL_FOUND session=${SESSION} sentinel=${SENTINEL}"
    exit 0
  fi

  if has_sentinel_file; then
    log_event tmux_wait_sentinel_result "status=SENTINEL_FOUND" "session=${SESSION}" "sentinel=${SENTINEL}" "mode=file_fallback"
    echo "SENTINEL_FOUND session=${SESSION} sentinel=${SENTINEL} mode=file_fallback"
    exit 0
  fi

  if [[ "${ALLOW_EXISTING}" == "1" ]]; then
    pane_tail="$(tail_window "${pane}")"
    if has_exact_sentinel_line "${pane_tail}"; then
      log_event tmux_wait_sentinel_result "status=SENTINEL_FOUND" "session=${SESSION}" "sentinel=${SENTINEL}" "mode=tail_fallback"
      echo "SENTINEL_FOUND session=${SESSION} sentinel=${SENTINEL} mode=tail_fallback"
      exit 0
    fi
  fi

  sleep "${POLL}"
done
